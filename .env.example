# Copy this file to .env for local development. Never commit real secrets.

POSTGRES_URL="postgres://postgres.[USERNAME]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# Optional local target for `pnpm run news:health:remote`.
NEWS_HEALTH_URL=""

# Protects the manual enqueue endpoints. Use at least 16 characters.
NEWS_REFRESH_SECRET=""

# Shared by the cron scheduler and the protected Next.js cron endpoints.
CRON_SECRET=""
CRON_BASE_URL="http://localhost:3000"

# Background worker embedding configuration.
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
NEWS_EMBED_LIMIT="25"

# Optional background worker tuning.
BACKGROUND_WORKER_ID=""
BACKGROUND_WORKER_IDLE_MS="5000"
BACKGROUND_WORKER_ERROR_MS="15000"
BACKGROUND_WORKER_LEASE_MS="300000"
BACKGROUND_WORKER_HEARTBEAT_MS="60000"

# Production auth. Generate secrets with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=""
AUTH_SECRET=""

# Optional Discord OAuth provider. Configure both values together.
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
