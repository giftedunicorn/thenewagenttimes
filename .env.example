# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# The database URL is used to connect to your Supabase database.
POSTGRES_URL="postgres://postgres.[USERNAME]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?workaround=supabase-pooler.vercel"

# Optional for local scripts that check a deployed app's /api/news/health endpoint.
# Accepts the app base URL, /api/news/health, /api/news/refresh, or /api/news/embed.
# On Railway, news:health:remote can fall back to NEWS_REFRESH_URL,
# NEWS_EMBED_URL, NEWS_BOOTSTRAP_URL, or RAILWAY_PUBLIC_DOMAIN when this is empty.
NEWS_HEALTH_URL=""

# Optional for local scripts that run the remote production bootstrap sequence.
# Accepts the app base URL, /api/news/health, /api/news/refresh, or /api/news/embed.
# On Railway, news:bootstrap:remote can fall back to NEWS_HEALTH_URL,
# NEWS_REFRESH_URL, NEWS_EMBED_URL, or RAILWAY_PUBLIC_DOMAIN when this is empty.
NEWS_BOOTSTRAP_URL=""

# Optional for local scripts, custom domains, or non-Railway schedulers that call a deployed app's refresh endpoint.
# Accepts the app base URL, /api/news/refresh, /api/news/health, or /api/news/embed.
# On Railway, news:refresh:remote can fall back to NEWS_HEALTH_URL,
# NEWS_EMBED_URL, or RAILWAY_PUBLIC_DOMAIN when this is empty.
NEWS_REFRESH_URL=""

# Optional for local scripts, custom domains, or non-Railway schedulers that call a deployed app's embedding endpoint.
# Accepts either the app base URL or the full /api/news/embed URL.
# On Railway, news:embed:remote can fall back to NEWS_HEALTH_URL, NEWS_REFRESH_URL, or RAILWAY_PUBLIC_DOMAIN when this is empty.
NEWS_EMBED_URL=""

# Optional remote embedding batch size for news:embed:remote.
NEWS_EMBED_LIMIT="25"

# Optional maximum embedding batches for news:bootstrap:remote. Defaults to 1.
NEWS_BOOTSTRAP_EMBED_BATCHES="1"

# Required for scheduled or manual production refresh calls to POST /api/news/refresh.
# Use at least 16 characters, then send it as either:
# Authorization: Bearer <secret>
# x-news-refresh-secret: <secret>
NEWS_REFRESH_SECRET=""

# Required for semantic recommendation embeddings when running `pnpm run news:embed:pending`.
OPENAI_API_KEY=""

# Optional embedding model override. Defaults to text-embedding-3-small.
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Optional unless auth endpoints are enabled. You can generate the secret via 'openssl rand -base64 32' on Unix.
# @see https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
AUTH_SECRET=""

# Optional Discord OAuth provider. Configure both values to enable Discord sign-in.
# @see https://www.better-auth.com/docs/authentication/discord
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
